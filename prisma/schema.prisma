generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Currency {
  RUB
  USD
  EUR
  GBP
  KZT
  UAH
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String?
  image          String?
  familyId       String?
  family         Family?   @relation(fields: [familyId], references: [id])
  accounts       Account[]
  sessions       Session[]
  transactions   Transaction[]
  createdGoals   Goal[]    @relation("GoalCreator")
  invites        FamilyInvite[] @relation("Invitee")
  recurringTemplates RecurringTransaction[]
  telegramChatId String?
  telegramLinkToken String? @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("users")
}

model Family {
  id            String        @id @default(cuid())
  name          String
  baseCurrency  Currency      @default(RUB)
  members       User[]
  transactions  Transaction[]
  goals         Goal[]
  invites       FamilyInvite[]
  categories    Category[]
  budgets       Budget[]
  recurring     RecurringTransaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("families")
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Float
  type        TransactionType
  category    String
  description String?
  currency    Currency
  date        DateTime        @default(now())
  userId      String
  familyId    String
  user        User            @relation(fields: [userId], references: [id])
  family      Family          @relation(fields: [familyId], references: [id])
  goalId      String?
  goal        Goal?           @relation(fields: [goalId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("transactions")
}

model Goal {
  id            String        @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float         @default(0)
  currency      Currency
  deadline      DateTime?
  familyId      String
  family        Family        @relation(fields: [familyId], references: [id])
  createdById   String
  createdBy     User          @relation("GoalCreator", fields: [createdById], references: [id])
  transactions  Transaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("goals")
}

model FamilyInvite {
  id        String   @id @default(cuid())
  token     String   @unique
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])
  inviteeId String
  invitee   User     @relation("Invitee", fields: [inviteeId], references: [id])
  accepted  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("family_invites")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  type      TransactionType
  icon      String?
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([name, familyId, type])
  @@map("categories")
}

model Budget {
  id        String   @id @default(cuid())
  category  String
  amount    Float
  period    String   @default("monthly")
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, familyId, period])
  @@map("budgets")
}

model RecurringTransaction {
  id          String          @id @default(cuid())
  amount      Float
  type        TransactionType
  category    String
  description String?
  currency    Currency
  frequency   Frequency
  nextDate    DateTime
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId    String
  family      Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("recurring_transactions")
}

model ExchangeRate {
  id        String   @id @default(cuid())
  from      Currency
  to        Currency
  rate      Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([from, to, date])
  @@map("exchange_rates")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}
