# Копируй в .env и заполни значениями
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth
AUTH_SECRET="генерируй: openssl rand -base64 32"
NEXTAUTH_URL="https://твой-домен.vercel.app"

# Exchange rates API (опционально)
EXCHANGE_RATE_API_KEY=""

# Telegram Bot (опционально)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="your_bot_username"

# Cron secret (для защиты /api/cron/daily)
CRON_SECRET=""

# Tinkoff worker (деплой worker/ на Render/Railway)
TINKOFF_WORKER_URL="https://your-worker.onrender.com"
WORKER_AUTH_TOKEN="some-secret-token"
