# Копируй в .env и заполни значениями
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth
AUTH_SECRET="генерируй: openssl rand -base64 32"
NEXTAUTH_URL="https://твой-домен.vercel.app"

# AI — OpenRouter (бесплатно) или OpenAI
# Регистрация: https://openrouter.ai — даёт бесплатные кредиты
AI_API_KEY=""
AI_BASE_URL="https://openrouter.ai/api/v1"
AI_MODEL="google/gemma-3-4b-it:free"
AI_VISION_MODEL="nvidia/nemotron-nano-12b-v2-vl:free"
# Для OpenAI вместо OpenRouter:
# AI_API_KEY="sk-..."
# AI_BASE_URL="https://api.openai.com/v1"
# AI_MODEL="gpt-4o-mini"
# AI_VISION_MODEL="gpt-4o-mini"

# Exchange rates API (опционально)
EXCHANGE_RATE_API_KEY=""

# Telegram Bot (опционально)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="your_bot_username"

# Cron secret (для защиты /api/cron/daily)
CRON_SECRET=""
